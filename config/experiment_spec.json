{
  "datasets_root": "datasets",
  "results_root": "results",
  "repo_path": "kubernetes",
  "constraints_file": "constraints/api_conventions_atomic_constraints_73.json",
  "agent_configs": [
    {
      "run_id": "agentic_inline_constraints",
      "model": "agent-model",
      "max_tokens": 8192,
      "context_strategy": "inline_constraints",
      "docker": {
        "image": "k8s-bench-agent",
        "agent_command": "agent run \"$AGENT_PROMPT_PATH\"",
        "docker_args": []
      }
    },
    {
      "run_id": "agentic_no_constraints",
      "model": "agent-model",
      "max_tokens": 8192,
      "context_strategy": "no_constraints",
      "docker": {
        "image": "k8s-bench-agent",
        "agent_command": "agent run \"$AGENT_PROMPT_PATH\"",
        "docker_args": []
      }
    }
  ],
  "judge_config": {
    "model": "kimi-k2-thinking",
    "max_tokens": 1024,
    "system_prompt": "You are an impartial judge evaluating whether a code patch newly satisfies a single atomic Kubernetes API convention rule. Respond strictly with a JSON object containing `verdict` (compliant | violated | not_applicable), `patch_effect` (applied_by_patch | already_satisfied | not_relevant | unknown), `confidence` (0..1), and `rationale`.",
    "client": {
      "client_type": "openai_compatible",
      "api_key_env": "OPENCODE_API_KEY",
      "base_url": "https://opencode.ai/zen/go/v1"
    },
    "judge_mode": "reference_based"
  }
}
