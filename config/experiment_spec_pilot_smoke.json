{
  "datasets_root": "datasets",
  "results_root": "results/pilot_smoke",
  "repo_path": "kubernetes",
  "constraints_file": "constraints/api_conventions_atomic_constraints_73.json",
  "instance_limit": 1,
  "agent_configs": [
    {
      "run_id": "smoke_deepseek_v4_flash_no_constraints",
      "model": "opencode-go/deepseek-v4-flash",
      "max_tokens": 8192,
      "context_strategy": "no_constraints",
      "docker": {
        "image": "k8s-bench-agent",
        "agent_command": "opencode run --dangerously-skip-permissions --model \"$MODEL\" < \"$AGENT_PROMPT_PATH\"",
        "docker_args": []
      },
      "skip_existing": false,
      "keep_worktree": true,
      "keep_failed_worktree": true
    }
  ],
  "judge_config": {
    "model": "deepseek-v4-flash",
    "max_tokens": 1024,
    "system_prompt": "You are an impartial judge evaluating whether a code patch complies with a single atomic Kubernetes API convention rule. Respond strictly with a JSON object containing `verdict` (compliant | violated | not_applicable), `confidence` (0..1), and `rationale`.",
    "client": {
      "client_type": "openai_compatible",
      "api_key_env": "OPENCODE_API_KEY",
      "base_url": "https://opencode.ai/zen/go/v1"
    },
    "judge_mode": "reference_based"
  }
}
