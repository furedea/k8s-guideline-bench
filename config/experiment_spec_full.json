      "docker": {
        "image": "k8s-bench-agent",
        "agent_command": "opencode run --model \"$MODEL\" < \"$AGENT_PROMPT_PATH\"",
        "docker_args": []
      },
      "context_files": [
        {
          "source_path": "constraints/api_conventions_atomic_constraints_73.json",
